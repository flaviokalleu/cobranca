# Exemplo de configuracao para o MODO PRODUCAO.
# Copie para .env.production e ajuste. Requer `docker compose up -d`.

DATABASE_URL="postgresql://cobranca:cobranca@localhost:5432/cobranca?schema=public"
PORT=3000

JWT_SECRET="GERE-UM-SEGREDO-LONGO-E-ALEATORIO-AQUI"
SWAGGER_BASIC_USER=""
SWAGGER_BASIC_PASSWORD=""

QUEUE_DRIVER="bullmq"
REDIS_URL="redis://localhost:6379"

REMINDER_SENDER="whaileys"

PIX_KEY="sua-chave-pix@exemplo.com"
PIX_MERCHANT_NAME="Sua Empresa"
PIX_MERCHANT_CITY="Sua Cidade"

SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="no-reply@seudominio.com"
