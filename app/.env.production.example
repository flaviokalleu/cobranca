# Exemplo de configuracao para o MODO PRODUCAO.
# Copie para .env e ajuste. Requer `docker compose up -d` (Postgres + Redis).
#
# IMPORTANTE: troque tambem o provider no prisma/schema.prisma:
#   datasource db { provider = "postgresql"  url = env("DATABASE_URL") }
# e rode:  npx prisma migrate deploy   (ou: npx prisma db push)

DATABASE_URL="postgresql://cobranca:cobranca@localhost:5432/cobranca?schema=public"
PORT=3000

JWT_SECRET="GERE-UM-SEGREDO-LONGO-E-ALEATORIO-AQUI"

QUEUE_DRIVER="bullmq"
REDIS_URL="redis://localhost:6379"

REMINDER_SENDER="baileys"

PIX_KEY="sua-chave-pix@exemplo.com"
PIX_MERCHANT_NAME="Sua Empresa"
PIX_MERCHANT_CITY="Sua Cidade"
