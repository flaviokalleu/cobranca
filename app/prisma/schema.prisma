// Modelo de dados do nucleo de cobranca.
// Banco: PostgreSQL. Dinheiro sempre em CENTAVOS (Int) — nunca float.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/// Cliente devedor, sempre dentro de um tenant (empresa).
model Customer {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  document        String?
  phone           String
  whatsapp        String?
  email           String?
  address         String?
  city            String?
  profession      String?
  incomeCents     Int?
  stage           String   @default("LEAD") // LEAD | FIRST_CONTACT | DOCUMENTATION | ANALYSIS | APPROVED | CONTRACT | CUSTOMER | LOST
  asaasCustomerId String?  // ID do cliente no Asaas (para reutilizar em cobranças)
  createdAt       DateTime @default(now())
  charges         Charge[]
  loans           Loan[]
  lead            Lead?

  @@index([tenantId])
  @@index([tenantId, stage])
}

/// Cobranca emitida para um cliente.
model Charge {
  id              String    @id @default(cuid())
  tenantId        String
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  salesOrderId    String?
  accountPlanId   String?
  amountCents     Int
  description     String
  dueDate         DateTime
  status          String    @default("PENDING") // PENDING | PAID | CANCELED
  category        String?
  recurrence      String    @default("ONCE") // ONCE | MONTHLY
  nextDueAt       DateTime?
  createdAt       DateTime  @default(now())
  paidAt          DateTime?
  paidAmountCents Int?
  gatewayProvider  String?
  gatewayChargeId  String?
  paymentLink      String?  // invoiceUrl do Asaas (portal de pagamento)
  bankSlipUrl      String?  // URL do boleto (Asaas)
  pixCode          String?  // PIX copia-e-cola local
  publicToken     String?   @unique
  interestMode    String    @default("NONE") // NONE | DAILY | WEEKLY | MONTHLY
  interestRateBps Int       @default(0)
  interestGraceDays Int     @default(0)
  nfe             NFe?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, recurrence, nextDueAt])
}

/// Emprestimo ou credito pessoal formalizado para um cliente.
model Loan {
  id                String            @id @default(cuid())
  tenantId          String
  customerId        String
  customer          Customer          @relation(fields: [customerId], references: [id])
  principalCents    Int
  totalCents        Int
  cetPercent        Float
  interestRate      Float
  interestType      LoanInterest
  installments      Int
  firstDueAt        DateTime
  lateFeePercent    Float             @default(2.0)
  lateInterestDaily Float             @default(0.033)
  status            LoanStatus        @default(DRAFT)
  contractSignedAt  DateTime?
  contractUrl       String?
  disbursedAt       DateTime?
  quitedAt          DateTime?
  installmentsList  LoanInstallment[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

enum LoanStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  PAID
  DEFAULTED
  CANCELED
}

enum LoanInterest {
  MONTHLY
  YEARLY
}

model LoanInstallment {
  id              String            @id @default(cuid())
  tenantId        String
  loanId          String
  loan            Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  number          Int
  principalCents  Int
  interestCents   Int
  totalCents      Int
  dueAt           DateTime
  paidAt          DateTime?
  paidAmountCents Int?
  status          InstallmentStatus @default(PENDING)
  chargeId        String?

  @@index([loanId])
  @@index([tenantId, dueAt])
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}

/// Template reutilizavel para criar cobrancas rapidamente.
model ChargeTemplate {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  description  String
  amountCents  Int
  recurrence   String   @default("ONCE")
  daysUntilDue Int      @default(30)
  category     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

/// Nota fiscal emitida ou simulada para uma cobranca.
model NFe {
  id             String   @id @default(cuid())
  tenantId       String
  chargeId       String   @unique
  charge         Charge   @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  provider       String   @default("nuvem-fiscal")
  externalId     String?
  status         String   @default("PENDING") // PENDING | PROCESSING | AUTHORIZED | REJECTED | CANCELED | SANDBOX
  xml            String?
  pdfUrl         String?
  error          String?
  payload        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

/// Plano de contas configuravel para DRE e lancamentos.
model AccountPlan {
  id        String        @id @default(cuid())
  tenantId  String
  code      String
  name      String
  type      String        // REVENUE | EXPENSE | ASSET | LIABILITY
  parentId  String?
  parent    AccountPlan?  @relation("AccountPlanChildren", fields: [parentId], references: [id])
  children  AccountPlan[] @relation("AccountPlanChildren")
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  @@unique([tenantId, code])
  @@index([tenantId, type])
}

/// Resultado persistido de reconciliacao bancaria.
model ReconciliationResult {
  id                String   @id @default(cuid())
  tenantId          String
  accountId         String
  period            String
  matchedCount      Int      @default(0)
  suspectCount      Int      @default(0)
  unmatchedCount    Int      @default(0)
  totalMatchedCents Int      @default(0)
  details           Json
  createdAt         DateTime @default(now())

  @@index([tenantId, period])
  @@index([tenantId, accountId])
}

/// Calculo tributario estimado.
model TaxCalculation {
  id                  String   @id @default(cuid())
  tenantId            String
  regime              String
  period              String
  revenue12mCents     Int
  revenueMonthCents   Int
  dasCents            Int
  effectiveRateBps    Int
  breakdown           Json
  createdAt           DateTime @default(now())

  @@index([tenantId, period])
}

/// Convite para usuario entrar no tenant.
model Invitation {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  role      String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, email])
}

/// Permissoes configuraveis por role e recurso.
model Permission {
  id        String   @id @default(cuid())
  tenantId  String?
  role      String
  resource  String
  actions   String[]
  createdAt DateTime @default(now())

  @@unique([tenantId, role, resource])
}

/// Assinatura Web Push do navegador.
model PushSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  endpoint  String   @unique
  p256dh     String
  auth      String
  createdAt DateTime @default(now())

  @@index([tenantId])
}

/// Log de mensagens processadas pelo bot principal.
model BotMessageLog {
  id          String   @id @default(cuid())
  tenantId    String
  from        String
  messageType String
  content     String?
  processedAs String?
  confidence  Float?
  entryId     String?
  error       String?
  processedAt DateTime @default(now())

  @@index([tenantId, processedAt])
}

/// Lancamento contabil (partida dobrada). Cada transacao gera 2+ entradas que se equilibram.
model LedgerEntry {
  id            String   @id @default(cuid())
  tenantId      String
  transactionId String
  accountCode   String // ACCOUNTS_RECEIVABLE | REVENUE | CASH
  accountPlanId String?
  direction     String // DEBIT | CREDIT
  amountCents   Int
  description   String
  createdAt     DateTime @default(now())

  @@index([tenantId, accountCode])
  @@index([transactionId])
}

/// Configuracoes por tenant (dados do recebedor PIX).
model Settings {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  pixKey           String
  merchantName     String
  merchantCity     String
  companyName      String?
  companyCnpj      String?
  companyPhone     String?
  companyEmail     String?
  companyAddress   String?
  companyCity      String?
  companyState     String?
  logoUrl          String?
  businessHoursStart String?
  businessHoursEnd   String?
  reminderDaysBefore Int    @default(3)
  defaultDueDays     Int    @default(30)
  notifyByEmail      Boolean @default(false)
  notifyByWhatsapp   Boolean @default(true)
  timezone           String  @default("America/Sao_Paulo")
  nfeEnabled       Boolean  @default(false)
  nfeCnpj          String?
  nfeRazaoSocial   String?
  nfeCodServico    String?
  nfeCodMunicipio  String?
  theme            String   @default("system")
  paymentProvider    String   @default("NONE") // NONE | ASAAS | MERCADOPAGO
  asaasApiKey        String?
  mercadoPagoToken   String?
  chargeRobotEnabled Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

/// Usuario do sistema, sempre dentro de um tenant. Senha guardada como hash (bcrypt).
model User {
  id                   String   @id @default(cuid())
  tenantId             String
  email                String
  passwordHash         String
  role                 String   @default("ADMIN") // ADMIN | FINANCE | COMMERCIAL | OPERATIONS | USER | SUPERADMIN
  twoFactorSecret      String?
  twoFactorEnabled     Boolean  @default(false)
  twoFactorBackupCodes String[] @default([])
  createdAt            DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}

/// Trilha de auditoria: toda mudanca de estado relevante e registrada aqui.
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actor      String
  action     String
  entityType String
  entityId   String
  metadata   String? // JSON serializado
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
}

// ===================== ERP =====================

/// Fornecedor.
model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  document  String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

/// Produto (com saldo de estoque embutido em stockQty).
model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  description String?
  priceCents  Int      @default(0)
  costCents   Int      @default(0)
  stockQty    Int      @default(0)
  unit        String   @default("UN")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

/// Movimentacao de estoque (historico).
model StockMovement {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  type      String // IN | OUT | ADJUST
  qty       Int
  reason    String
  refType   String?
  refId     String?
  createdAt DateTime @default(now())

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
}

/// Pedido de venda.
model SalesOrder {
  id         String   @id @default(cuid())
  tenantId   String
  number     Int
  customerId String
  status     String   @default("DRAFT") // DRAFT | CONFIRMED | CANCELED
  totalCents Int      @default(0)
  chargeId   String?
  deliveryAt DateTime?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
}

model SalesOrderItem {
  id             String @id @default(cuid())
  tenantId       String
  orderId        String
  productId      String
  qty            Int
  unitPriceCents Int
  totalCents     Int

  @@index([orderId])
}

/// Pedido de compra.
model PurchaseOrder {
  id         String   @id @default(cuid())
  tenantId   String
  number     Int
  supplierId String
  status     String   @default("DRAFT") // DRAFT | RECEIVED | CANCELED
  totalCents Int      @default(0)
  payableId  String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id            String @id @default(cuid())
  tenantId      String
  orderId       String
  productId     String
  qty           Int
  unitCostCents Int
  totalCents    Int

  @@index([orderId])
}

/// Conta a pagar.
model Payable {
  id          String    @id @default(cuid())
  tenantId    String
  supplierId  String?
  description String
  amountCents Int
  dueDate     DateTime
  status      String    @default("PENDING") // PENDING | PAID | CANCELED
  paidAt      DateTime?
  category    String?
  accountPlanId String?
  recurrence  String    @default("ONCE") // ONCE | MONTHLY
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
}

/// Tarefa / item de checklist.
model Task {
  id        String    @id @default(cuid())
  tenantId  String
  parentId  String?
  title     String
  notes     String?
  done      Boolean   @default(false)
  dueDate   DateTime?
  priority  String    @default("MED") // LOW | MED | HIGH
  assignee  String?
  assigneeId String?
  recurrence String    @default("NONE") // NONE | DAILY | WEEKLY | MONTHLY
  nextOccurrenceAt DateTime?
  estimatedMinutes Int?
  completedAt DateTime?
  createdAt DateTime  @default(now())
  parent    Task?     @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks  Task[]    @relation("TaskSubtasks")

  @@index([tenantId, done])
  @@index([tenantId, parentId])
}

/// Lead do CRM.
model Lead {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  contact        String?
  document       String?
  phone          String?
  whatsapp       String?
  email          String?
  city           String?
  profession     String?
  incomeCents    Int?
  estimatedCents Int      @default(0)
  stage          String   @default("LEAD") // LEAD | FIRST_CONTACT | DOCUMENTATION | ANALYSIS | APPROVED | CONTRACT | CUSTOMER | LOST
  notes             String?
  createdAt         DateTime         @default(now())
  customerId        String?          @unique
  customer          Customer?        @relation(fields: [customerId], references: [id])
  financialEntries  FinancialEntry[]

  @@index([tenantId, stage])
}

/// Requisito reutilizavel para checklist documental.
model DocumentRequirement {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String   @default("GENERAL")
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([tenantId, category])
}

/// Documento anexado ou pendente em uma pasta digital de cliente.
model CustomerDocument {
  id            String    @id @default(cuid())
  tenantId      String
  customerId    String
  requirementId String?
  name          String
  status        String    @default("NOT_SENT") // NOT_SENT | SENT | IN_REVIEW | APPROVED | REJECTED
  fileName      String?
  fileUrl       String?
  notes         String?
  uploadedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

/// Evento operacional para calendario, visitas, vencimentos e tarefas.
model CalendarEvent {
  id         String    @id @default(cuid())
  tenantId   String
  title      String
  type       String    @default("MEETING") // MEETING | VISIT | CHARGE | CONTRACT | DUE_DATE | TASK
  startsAt   DateTime
  endsAt     DateTime?
  status     String    @default("SCHEDULED") // SCHEDULED | DONE | CANCELED
  customerId String?
  chargeId   String?
  payableId  String?
  taskId     String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId, startsAt])
  @@index([tenantId, status])
}

/// Central de notificacoes e fila logica de alertas.
model Notification {
  id          String    @id @default(cuid())
  tenantId    String
  channel     String    @default("SYSTEM") // SYSTEM | WHATSAPP | EMAIL
  title       String
  message     String
  recipientEmail String?
  status      String    @default("UNREAD") // UNREAD | READ | QUEUED | SENT | FAILED
  entityType  String?
  entityId    String?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// ===================== WhatsApp Personal Finance =====================

/// Conta, carteira ou saldo usado no controle financeiro pessoal.
model PersonalFinanceAccount {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  type         String   @default("CHECKING") // CHECKING | SAVINGS | CASH | INVESTMENT | WALLET
  balanceCents Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

/// Cartao de credito controlado pelo usuario.
model PersonalCreditCard {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  limitCents Int      @default(0)
  closingDay Int?
  dueDay     Int?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

/// Transacao criada manualmente, por WhatsApp ou por integracao.
model PersonalFinanceTransaction {
  id            String   @id @default(cuid())
  tenantId      String
  accountId     String?
  cardId        String?
  type          String // EXPENSE | INCOME | TRANSFER
  amountCents   Int
  description   String
  category      String   @default("Outros")
  subcategory   String?
  occurredAt    DateTime
  source        String   @default("MANUAL") // MANUAL | WHATSAPP_TEXT | WHATSAPP_AUDIO | WHATSAPP_IMAGE | WHATSAPP_PDF | IMPORT
  rawInput      String?
  attachmentUrl String?
  classifier    String   @default("RULES")
  confidence    Int      @default(70)
  createdAt     DateTime @default(now())

  @@index([tenantId, occurredAt])
  @@index([tenantId, category])
  @@index([tenantId, type])
}

/// Limite de gasto por categoria.
model SpendingLimit {
  id                    String   @id @default(cuid())
  tenantId              String
  category              String
  period                String   @default("MONTHLY") // MONTHLY | WEEKLY
  limitCents            Int
  alertThresholdPercent Int      @default(80)
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())

  @@index([tenantId, category])
}

/// Meta financeira ou de investimento.
model InvestmentGoal {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  targetCents  Int
  currentCents Int       @default(0)
  dueDate      DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([tenantId])
}

/// Conexao futura com banco, cartao ou carteira de investimentos.
model ConnectedFinanceProvider {
  id           String    @id @default(cuid())
  tenantId     String
  provider     String
  kind         String    @default("BANK") // BANK | CREDIT_CARD | INVESTMENT
  status       String    @default("DISCONNECTED") // DISCONNECTED | CONNECTED | ERROR
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenantId, provider])
}

// ===================== Main WhatsApp Bot / Finance Receipts =====================

/// WhatsApp principal usado pelo robo da plataforma. E global, nao pertence a um tenant.
model MainWhatsappBot {
  id                String    @id @default(cuid())
  phone             String?
  profileName       String?
  profilePictureUrl String?
  status            String    @default("disconnected") // active | inactive | blocked | disconnected | connected | error | session_expired
  isActive          Boolean   @default(true)
  welcomeMessage    String?
  alertPhone        String?
  connectedAt       DateTime?
  disconnectedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([isActive])
}

/// Estado da conexao do WhatsApp principal.
model WhatsappConnection {
  id                String    @id @default(cuid())
  status            String    @default("disconnected") // disconnected | waiting_qr | connecting | connected | reconnecting | error | session_expired
  phone             String?
  profileName       String?
  profilePictureUrl String?
  connectedAt       DateTime?
  disconnectedAt    DateTime?
  lastQrGeneratedAt DateTime?
  lastError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions WhatsappSession[]
  logs     WhatsappConnectionLog[]

  @@index([status])
}

/// Credenciais principais da sessao Whaileys, sempre criptografadas antes de persistir.
model WhatsappSession {
  id           String              @id @default(cuid())
  connectionId String?
  connection   WhatsappConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sessionName  String              @default("main-bot")
  creds        String
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  keys WhatsappSessionKey[]

  @@index([sessionName])
  @@index([isActive])
}

/// Chaves individuais da sessao Whaileys, criptografadas e atualizadas incrementalmente.
model WhatsappSessionKey {
  id        String          @id @default(cuid())
  sessionId String
  session   WhatsappSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  keyType   String
  keyId     String
  keyValue  String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([sessionId, keyType, keyId])
  @@index([keyType])
  @@index([sessionId])
}

/// Logs administrativos da conexao principal do WhatsApp.
model WhatsappConnectionLog {
  id           String              @id @default(cuid())
  connectionId String?
  connection   WhatsappConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  adminId      String?
  action       String
  status       String?
  description  String?
  metadata     String?
  createdAt    DateTime            @default(now())

  @@index([connectionId])
  @@index([createdAt])
}

/// Logs operacionais de mensagens do WhatsApp principal, sem persistir conteudo sensivel completo.
model WhatsappMessageLog {
  id          String   @id @default(cuid())
  direction   String   @default("INBOUND") // INBOUND | OUTBOUND
  jid         String?
  phone       String?
  messageType String?
  status      String   @default("received") // received | processed | sent | ignored | error
  description String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([status])
  @@index([direction])
}

/// Codigo de ativacao emitido para uma empresa (Tenant). O codigo puro nunca e armazenado.
model CompanyActivationCode {
  id          String    @id @default(cuid())
  tenantId    String
  reference   String    @unique
  codeHash    String
  codePrefix  String
  role        String    @default("FINANCE")
  permissions String?
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  status      String    @default("ACTIVE") // ACTIVE | USED | EXPIRED | REVOKED
  createdBy   String?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([codePrefix])
  @@index([status])
}

/// Numero de WhatsApp ativado e vinculado a empresa correta.
model WhatsappUser {
  id          String    @id @default(cuid())
  tenantId    String
  phone       String    @unique
  displayName String?
  role        String    @default("FINANCE")
  permissions String?
  status      String    @default("ACTIVE") // ACTIVE | INACTIVE | BLOCKED
  activatedAt DateTime  @default(now())
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
}

/// Estado temporario de conversa por usuario/empresa, com expiracao.
model WhatsappUserState {
  id             String   @id @default(cuid())
  tenantId       String
  whatsappUserId String
  phone          String   @unique
  state          String
  payload        String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([whatsappUserId])
  @@index([expiresAt])
}

/// Logs de ativacao e uso bloqueado por status/permissao.
model CompanyActivationLog {
  id             String   @id @default(cuid())
  tenantId       String
  whatsappUserId String?
  phone          String?
  action         String
  status         String?
  description    String?
  metadata       String?
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}

/// Lancamento financeiro confirmado via WhatsApp. Valores em centavos para consistencia.
model FinancialEntry {
  id                   String    @id @default(cuid())
  tenantId             String
  whatsappUserId       String
  userWhatsapp         String
  tipo                 String // receita | gasto
  valorCents           Int
  moeda                String    @default("BRL")
  dataTransacao        DateTime?
  horaTransacao        String?
  pagadorNome          String?
  pagadorDocumento     String?
  pagadorInstituicao   String?
  recebedorNome        String?
  recebedorDocumento   String?
  recebedorInstituicao String?
  chavePix             String?
  tipoTransferencia    String?
  idTransacao          String?
  codigoAutenticacao   String?
  numeroControle       String?
  bancoEmissor         String?
  situacao             String?
  descricao            String
  observacao           String?
  confianca            String
  fonteExtracao        String
  arquivoUrl           String?
  jsonOriginal         String?
  recorrencia          String    @default("AVULSO") // AVULSO | MENSAL
  leadId               String?
  accountPlanId        String?
  lead                 Lead?     @relation(fields: [leadId], references: [id])
  status               String    @default("pending_confirmation") // pending_confirmation | saved | corrected | cancelled | error
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, recorrencia])
  @@index([tenantId, whatsappUserId])
}

// ===================== Open Finance =====================

/// Conexao com uma instituicao financeira via Open Finance (Pluggy).
model OpenFinanceConnection {
  id           String    @id @default(cuid())
  tenantId     String
  itemId       String    @unique // Pluggy item ID
  connector    String    // Nome da instituicao (ex: "Nubank", "Itau")
  connectorId  Int       // Pluggy connector ID
  status       String    @default("UPDATING") // UPDATING | UPDATED | WAITING_USER_INPUT | LOGIN_ERROR | OUTDATED | ERROR
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts     OpenFinanceBankAccount[]

  @@index([tenantId])
  @@index([tenantId, status])
}

/// Conta bancaria sincronizada via Open Finance.
model OpenFinanceBankAccount {
  id            String                  @id @default(cuid())
  tenantId      String
  connectionId  String
  connection    OpenFinanceConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  externalId    String                  @unique // Pluggy account ID
  type          String                  // BANK | CREDIT | INVESTMENT
  subtype       String?                 // CHECKING | SAVINGS | CREDIT_CARD
  name          String
  number        String?
  agency        String?
  currency      String                  @default("BRL")
  balanceCents  Int                     @default(0)
  creditLimitCents Int?
  lastSyncAt    DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  transactions  OpenFinanceTransaction[]

  @@index([tenantId])
  @@index([connectionId])
}

/// Transacao sincronizada de uma conta bancaria via Open Finance.
model OpenFinanceTransaction {
  id               String                 @id @default(cuid())
  tenantId         String
  accountId        String
  account          OpenFinanceBankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalId       String                 @unique // Pluggy transaction ID
  type             String                 // DEBIT | CREDIT
  amountCents      Int
  description      String
  category         String?
  date             DateTime
  balance          Int?
  counterpartyName String?
  paymentMethod    String?                // PIX | TED | DOC | BOLETO | CREDIT_CARD
  createdAt        DateTime               @default(now())

  @@index([tenantId, date])
  @@index([tenantId, category])
  @@index([accountId])
}

// ===================== SaaS / Plataforma =====================

/// Empresa cliente do SaaS. tenantId dos demais registros = Tenant.id.
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE") // ACTIVE | SUSPENDED
  createdAt DateTime @default(now())
}

/// Plano de assinatura da plataforma (editável pelo superadmin).
model Plan {
  id              String   @id @default(cuid())
  code            String   @unique // FREE | PRO | BUSINESS
  name            String
  priceCents      Int      @default(0)
  maxUsers        Int      @default(3)
  maxChargesMonth Int      @default(50)
  /// JSON array de módulos habilitados. Ex: ["pix","reminders","whatsapp_bot","charge_robot","ai_consultant","nfe"]
  features        String   @default("[]")
  createdAt       DateTime @default(now())
}

/// Assinatura da empresa (a plataforma cobra a empresa).
model Subscription {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  planCode         String    @default("FREE")
  status           String    @default("TRIALING") // TRIALING | ACTIVE | PAST_DUE | CANCELED
  currentPeriodEnd DateTime?
  gatewayChargeId  String?
  createdAt        DateTime  @default(now())
}

/// Configuração da plataforma (chave Asaas usada para cobrar as empresas). Linha única.
model PlatformSettings {
  id          String   @id
  asaasApiKey String?
  asaasEnv    String   @default("sandbox")
  updatedAt   DateTime @updatedAt
}

/// Registro de webhooks processados para garantir idempotencia.
model WebhookDelivery {
  id          String   @id @default(cuid())
  source      String   // ASAAS | MERCADOPAGO
  eventId     String   // ID do evento externo (payment.id ou similar)
  event       String   // PAYMENT_RECEIVED etc
  processedAt DateTime @default(now())

  @@unique([source, eventId])
  @@index([source, processedAt])
}
